{
  "name": "@jaywedgeworth22/congress-trading-shared",
  "version": "1.1.1",
  "description": "Shared types, Zod schemas, constants, and utilities for Congress.Trade ↔ Agentic Trading cross-app integration",
  "license": "UNLICENSED",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "pack:dry": "npm pack --dry-run",
    "prepare": "npm run build",
    "test": "npm run typecheck",
    "typecheck": "tsc --noEmit",
    "publish:dry": "npm publish --dry-run"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.3"
  },
  "overrides": {
    "esbuild": "0.28.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jaywedgeworth22/congress-trading-shared.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
