{
  "name": "@jaywedgeworth22/congress-trading-shared",
  "version": "1.9.0",
  "private": true,
  "type": "commonjs",
  "description": "Shared types, Zod schemas, constants, and utilities for Congress.Trade ↔ Socratic Trade cross-app integration",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "node -r ./tsup-preload.cjs node_modules/tsup/dist/cli-default.js src/index.ts --format cjs,esm --dts --clean",
    "lint:package": "publint",
    "pack:dry": "npm pack --dry-run",
    "prepare": "npm run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "publint": "^0.3.21",
    "tsup": "^8.3.5",
    "typescript": "^7.0.2",
    "typescript-v5": "npm:typescript@6.0.3",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "esbuild": "0.28.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jaywedgeworth22/congress-trading-shared.git"
  }
}
